{
  "env": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "global",
    "ANTHROPIC_VERTEX_PROJECT_ID": "rj-smtr",
    "VERTEX_REGION_CLAUDE_3_5_SONNET": "global",
    "VERTEX_REGION_CLAUDE_3_5_HAIKU": "global",
    "VERTEX_REGION_CLAUDE_3_7_SONNET": "global",
    "VERTEX_REGION_CLAUDE_4_0_OPUS": "global",
    "VERTEX_REGION_CLAUDE_4_0_SONNET": "global",
    "VERTEX_REGION_CLAUDE_4_1_OPUS": "global",
    "VERTEX_REGION_CLAUDE_4_5_SONNET": "global",
    "ANTHROPIC_MODEL": "claude-haiku-4-5@20251001",
    "ANTHROPIC_SMALL_FAST_MODEL": "claude-haiku-4-5@20251001"
  },
  "permissions": {
    "allow": [
      "Bash(ruff:*)",
      "Bash(sqlfmt:*)",
      "Bash(dbt parse:*)",
      "Bash(dbt compile:*)",
      "Bash(dbt deps:*)",
      "Bash(dbt ls:*)",
      "Bash(dbt build:*)",
      "Bash(dbt test:*)",
      "Bash(uv sync:*)",
      "Bash(uv run:*)",
      "Bash(pre-commit:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(git checkout:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(cookiecutter:*)",
      "Bash(uvx cookiecutter:*)",
      "Bash(mkdir:*)",
      "Bash(git config:*)",
      "Bash(gh api:*)",
      "Bash(docker ps:*)",
      "Bash(docker stop:*)",
      "Bash(gh pr:*)",
      "Bash(cat:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(rm -rf:*)"
    ]
  },
  "enabledPlugins": {
    "dbt@dbt-agent-marketplace": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty') && [[ \"$FILE\" == *.py ]] && [[ \"$FILE\" == *pipelines/* ]] && cd \"$CLAUDE_PROJECT_DIR\" && ruff check --fix \"$FILE\" && ruff format \"$FILE\" || true"
          },
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty') && [[ \"$FILE\" == *.sql ]] && [[ \"$FILE\" == *queries/* ]] && cd \"$CLAUDE_PROJECT_DIR\" && sqlfmt \"$FILE\" || true"
          },
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty') && [[ \"$FILE\" == *.sql ]] && [[ \"$FILE\" == *queries/models/* ]] && cd \"$CLAUDE_PROJECT_DIR/queries\" && dbt parse --quiet || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty') && if [[ \"$FILE\" == *.env* ]] || [[ \"$(basename \"$FILE\")\" == .env* ]]; then echo '{\"decision\": \"block\", \"reason\": \"Cannot edit .env files directly. Secrets are managed by Infisical SDK.\"}'; fi"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-create.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-remove.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
